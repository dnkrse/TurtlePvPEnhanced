        if pct then
            local cc = TBGH:GetClassColorByName(name)
            local cOpen = cc and ("|c" .. cc) or "|cffffd100"
            SendChatMessage("EFC: " .. cOpen .. name .. "|r - " .. pct .. "% Health", "BATTLEGROUND")
        end
    end
end)
