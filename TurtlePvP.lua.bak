-- Settings window
---------------------------------------------------------------------
local settingsFrame = CreateFrame("Frame", "TurtlePvPSettingsFrame", UIParent)
settingsFrame:SetWidth(340)
settingsFrame:SetHeight(400)
settingsFrame:SetPoint("CENTER", UIParent, "CENTER", 0, 60)
settingsFrame:SetFrameStrata("DIALOG")
settingsFrame:SetMovable(true)
settingsFrame:EnableMouse(true)
settingsFrame:SetClampedToScreen(true)
settingsFrame:RegisterForDrag("LeftButton")
settingsFrame:SetScript("OnDragStart", function() settingsFrame:StartMoving() end)
settingsFrame:SetScript("OnDragStop", function() settingsFrame:StopMovingOrSizing() end)
settingsFrame:SetBackdrop({
    bgFile = "Interface\\DialogFrame\\UI-DialogBox-Background",
    edgeFile = "Interface\\DialogFrame\\UI-DialogBox-Border",
    tile = true, tileSize = 32, edgeSize = 32,
    insets = { left = 11, right = 12, top = 12, bottom = 11 },
})
settingsFrame:Hide()

-- Track which section is being previewed: "ab", "bases", "wsg", or nil
local previewSection = nil

-- Title
local settingsTitle = settingsFrame:CreateFontString(nil, "OVERLAY", "GameFontNormalLarge")
settingsTitle:SetPoint("TOP", settingsFrame, "TOP", 0, -16)
settingsTitle:SetText("TurtlePvP")

-- Close button
local closeBtn = CreateFrame("Button", "TurtlePvPSettingsClose", settingsFrame, "UIPanelCloseButton")
closeBtn:SetPoint("TOPRIGHT", settingsFrame, "TOPRIGHT", -4, -4)

-- Preview background textures (shown when settings open)
local containerPreviewBG = container:CreateTexture("TurtlePvPContainerBG", "BACKGROUND")
containerPreviewBG:SetAllPoints(container)
containerPreviewBG:SetTexture(0, 0, 0, 0)

local basePreviewBG = baseContainer:CreateTexture("TurtlePvPBaseBG", "BACKGROUND")
basePreviewBG:SetAllPoints(baseContainer)
basePreviewBG:SetTexture(0, 0, 0, 0)

-- Hide all previews
local function HideAllPreviews()
    containerPreviewBG:SetTexture(0, 0, 0, 0)
    basePreviewBG:SetTexture(0, 0, 0, 0)
    baseBG:SetTexture(0, 0, 0, 0)
    if container._previewMode then
        container._previewMode = nil
        abAlliText:SetText("")
        abHordeText:SetText("")
        overlayText2:SetText("")
        overlayText3:SetText("")
        overlay:Hide()
        container:Hide()
    end
    if baseContainer._previewMode then
        baseContainer._previewMode = nil
        abBaseFrame:Hide()
        baseContainer:Hide()
        for i = 1, 5 do
            abBaseNames[i]:SetText("")
            abBaseCounts[i]:SetText("")
        end
    end
    if wsgFrame._previewMode then
        wsgFrame._previewMode = nil
        wsgAlliText:SetText("")
        wsgAlliHP:SetText("")
        wsgAlliDist:SetText("")
        wsgHordeText:SetText("")
        wsgHordeHP:SetText("")
        wsgHordeDist:SetText("")
        wsgFrame:Hide()
        if not overlay:IsShown() then container:Hide() end
    end
    previewSection = nil
end

-- Show preview for a specific section
local function ShowSectionPreview(section)
    HideAllPreviews()
    previewSection = section
    
    if section == "ab" then
        containerPreviewBG:SetTexture(0.1, 0.1, 0.4, 0.6)
        containerActiveBG = "ab"
        ApplyContainerPos(db.abPos)
        container:Show()
        overlay:Show()
        wsgFrame:Hide()
        abAlliText:SetText("|cff60b0ff1450|r")
        abHordeText:SetText("|cffff60601280|r")
        overlayText2:SetText("|cffffd100Win 3:45|r")
        overlayText3:SetText("|cffffd100Need 3 Bases|r")
        container._previewMode = true
        ResizeContainer()
    --[[ BASE DISPLAY FEATURE - DISABLED
    elseif section == "bases" then
        basePreviewBG:SetTexture(0.1, 0.1, 0.4, 0.6)
        baseBG:SetTexture(0.1, 0.1, 0.4, 0.6)
        baseContainer:Show()
        abBaseFrame:Show()
        for i = 1, 5 do
            abBaseNames[i]:SetText("|cff888888" .. AB_SHORT_NAMES[i] .. "|r")
            abBaseCounts[i]:SetText("|cff8888880|r")
        end
        baseContainer._previewMode = true
        ResizeBaseContainer()
    --]]
    elseif section == "wsg" then
        containerPreviewBG:SetTexture(0.1, 0.4, 0.1, 0.6)
        containerActiveBG = "wsg"
        ApplyContainerPos(db.wsgPos or DEFAULT_WSG_POS)
        container:Show()
        overlay:Hide()
        wsgFrame:Show()
        wsgAlliText:SetText("|cff3399ffPlayerName|r")
        wsgHordeText:SetText("|cffff3333PlayerName|r")
        -- Set sample class icons for preview (Warrior for Alliance side, Rogue for Horde side)
        wsgAlliClassIcon:SetTexture(CLASS_ICONS)
        wsgAlliClassIcon:SetTexCoord(0, 0.25, 0, 0.25)  -- Warrior
        wsgAlliClassIcon:SetAlpha(1)
        wsgAlliClassIcon:Show()
        wsgHordeClassIcon:SetTexture(CLASS_ICONS)
        wsgHordeClassIcon:SetTexCoord(0.5, 0.75, 0, 0.25)  -- Rogue
        wsgHordeClassIcon:SetAlpha(1)
        wsgHordeClassIcon:Show()
        wsgFrame._previewMode = true
        container._previewMode = true
        ResizeContainer()
    end
end

-- Helper to create a small button
local function CreateSmallButton(name, parent, text, width)
    local btn = CreateFrame("Button", name, parent, "UIPanelButtonTemplate")
    btn:SetWidth(width or 65)
    btn:SetHeight(22)
    btn:SetText(text)
    btn:GetFontString():SetFont("Fonts\\FRIZQT__.TTF", 10)
    return btn
end

-- Button layout constants (right-aligned)
local BTN_WIDTH = 65
local BTN_MARGIN = 8   -- margin from right edge of content frame
local BTN_GAP = 4      -- gap between buttons

