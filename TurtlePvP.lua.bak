-- TurtlePvP: BG helper for WoW 1.12 / Turtle WoW
-- AB: projected final score overlay   WSG: flag carrier names overlay
-- Commands: /tbg (AB estimate), /tbgdebug (WorldState dump), /tbgwsg (WSG status)

-- Check if we're in a battleground
local BG_ZONES = {
    ["Arathi Basin"] = "ab",
    ["Warsong Gulch"] = "wsg",
    ["Alterac Valley"] = "av",
}

function TBGH_GetBGType()
    local zone = GetRealZoneText()
    return BG_ZONES[zone] or nil
end

TBGH = {
    MAX = 2000,
    -- Resources per second by base count (vanilla 1.12 AB rates)
    RPS = { [0]=0, [1]=10/12, [2]=10/9, [3]=10/6, [4]=10/3, [5]=30 },
    prev = {},
    lastProjection = nil,
    -- WSG flag carrier state
    wsg = {
        alliCarrier = nil,  -- name of player carrying Alliance flag
        hordeCarrier = nil,  -- name of player carrying Horde flag
        -- Health threshold tracking for auto-announcements
        alliCarrierLastThreshold = nil,  -- last announced threshold (40 or 20)
        hordeCarrierLastThreshold = nil,
    },
    -- Nampower GUID tracker (name <-> GUID mapping)
    guidTracker = {
        nameToGuid = {},
        guidToName = {},
    },
    -- Capability flags (set at VARIABLES_LOADED)
    hasNampower = false,
    hasUnitXP = false,
    -- AB base short names (positions populated dynamically from map landmarks)
    AB_BASE_NAMES = {
        ["Stables"]    = "ST",
        ["Blacksmith"] = "BS",
        ["Lumber Mill"]= "LM",
        ["Gold Mine"]  = "GM",
        ["Farm"]       = "FM",
    },
    AB_BASES = {},  -- populated at runtime: { { name, x, y }, ... }
    AB_BASE_RANGE = 0.1,  -- range in normalized map coords (~10% of map)
    abBaseCounts = nil,   -- populated by ScanRaidPositions
    -- Rez wave tracking (global 30-second BG spirit healer cycle)
    rezWave = {
        lastWave = nil,   -- GetTime() of last detected rez wave
        deadSet = {},      -- [unitName] = true for currently dead raid members
    },
    -- Cap timer tracking
    capTimers = {},    -- [baseIdx] = GetTime() when assault started
    prevOwners = {},   -- [baseIdx] = previous TEX_* state
    CAP_DURATION = 60, -- seconds to capture a base
}

local frame = CreateFrame("Frame", "TurtlePvPFrame")
frame:RegisterEvent("UPDATE_WORLD_STATES")
frame:RegisterEvent("PLAYER_ENTERING_WORLD")
-- WSG flag events come through chat channels
frame:RegisterEvent("CHAT_MSG_BG_SYSTEM_ALLIANCE")
frame:RegisterEvent("CHAT_MSG_BG_SYSTEM_HORDE")
frame:RegisterEvent("CHAT_MSG_BG_SYSTEM_NEUTRAL")
frame:RegisterEvent("CHAT_MSG_RAID_BOSS_EMOTE")
frame:RegisterEvent("PLAYER_TARGET_CHANGED")
frame:RegisterEvent("UPDATE_MOUSEOVER_UNIT")
frame:RegisterEvent("VARIABLES_LOADED")
-- Nampower GUID events (registered conditionally after VARIABLES_LOADED)
-- UNIT_HEALTH_GUID, UNIT_AURA_GUID, SPELL_START_OTHER

---------------------------------------------------------------------
-- Shared movable container for all BG overlays
---------------------------------------------------------------------
local abParent = WorldStateAlwaysUpFrame or UIParent

-- Initialize DB (migrate old SavedVariables if present)
if not TurtlePvPDB then TurtlePvPDB = {} end
local db = TurtlePvPDB

local function ReloadDB()
    if not TurtlePvPDB then TurtlePvPDB = {} end
    db = TurtlePvPDB
    -- Migrate old SavedVariable names
    if TurtlePvPPos then db.abPos = TurtlePvPPos; TurtlePvPPos = nil end
    if TurtlePvPBasePos then db.basePos = TurtlePvPBasePos; TurtlePvPBasePos = nil end
    if TurtlePvPWSGPos then db.wsgPos = TurtlePvPWSGPos; TurtlePvPWSGPos = nil end
    -- Discard old-format positions (not TOPLEFT-based UIParent coords)
    if db.abPos and db.abPos.point ~= "TOPLEFT" then db.abPos = nil end
    if db.wsgPos and db.wsgPos.point ~= "TOPLEFT" then db.wsgPos = nil end
    if db.basePos and db.basePos.point ~= "TOPLEFT" then db.basePos = nil end
    -- Default module enable states
    if db.abEnabled == nil then db.abEnabled = true end
    if db.abBaseDisplayEnabled == nil then db.abBaseDisplayEnabled = false end  -- DISABLED: feature not ready
    if db.wsgEnabled == nil then db.wsgEnabled = true end
    if db.wsgAutoAnnounce == nil then db.wsgAutoAnnounce = true end  -- Auto-announce low EFC health
    -- Auto-signup defaults
    if db.autoSignup == nil    then db.autoSignup    = false end
    if db.autoSignupBGs == nil then db.autoSignupBGs = {[3]=true} end  -- keys: 3=WSG 4=AB 5=AV 6=Sunnyglade
    -- Combat module defaults
    if db.totemSkip == nil then db.totemSkip = true end
end

-- Run validation immediately (in case SavedVariables loaded before this file)
ReloadDB()

local container = CreateFrame("Button", "TurtlePvPContainer", UIParent)
container:SetWidth(300)
container:SetHeight(24)
container:SetFrameStrata("HIGH")
container:SetMovable(true)
container:SetClampedToScreen(true)
container:RegisterForClicks("LeftButtonUp")
container:RegisterForDrag("LeftButton")

-- Track which BG the container is currently showing for
local containerActiveBG = nil

-- Fixed default positions (UIParent TOPLEFT-relative)
local DEFAULT_CONTAINER_POS = { point = "TOPLEFT", relPoint = "TOPLEFT", x = 1133, y = -37 }
local DEFAULT_BASE_POS = { point = "TOPLEFT", relPoint = "TOPLEFT", x = 1077, y = -104 }
-- WSG default: same area as AB score overlay
local DEFAULT_WSG_POS = { point = "TOPLEFT", relPoint = "TOPLEFT", x = 1133, y = -37 }

-- Forward declaration for minimap button positioning (defined later with minimap button UI)
local UpdateMinimapBtnPos

-- Strip WoW color escape codes for SendChatMessage
local function StripColors(s)
    if not s then return s end
    s = string.gsub(s, "|c%x%x%x%x%x%x%x%x", "")
    s = string.gsub(s, "|r", "")
    return s
end

local function ApplyContainerPos(pos)
    container:ClearAllPoints()
    pos = pos or DEFAULT_CONTAINER_POS
    container:SetPoint(pos.point, UIParent, pos.relPoint, pos.x, pos.y)
end

local function SaveContainerPos()
    -- Save position relative to UIParent
    local left = container:GetLeft()
    local top = container:GetTop()
    if left and top then
        local uiTop = UIParent:GetTop() or top
        if containerActiveBG == "wsg" then
            -- WSG: save as TOPLEFT-relative (same as AB)
            db.wsgPos = { point = "TOPLEFT", relPoint = "TOPLEFT", x = left, y = top - uiTop }
        else
            db.abPos = { point = "TOPLEFT", relPoint = "TOPLEFT", x = left, y = top - uiTop }
        end
    end
end

-- Default position on load (will be overridden when a BG activates)
container:SetPoint(DEFAULT_CONTAINER_POS.point, UIParent, DEFAULT_CONTAINER_POS.relPoint,
    DEFAULT_CONTAINER_POS.x, DEFAULT_CONTAINER_POS.y)

container:SetScript("OnDragStart", function()
    if IsShiftKeyDown() or (TurtlePvPSettingsFrame and TurtlePvPSettingsFrame:IsShown()) then
        container:StartMoving()
    end
end)
container:SetScript("OnDragStop", function()
    container:StopMovingOrSizing()
    SaveContainerPos()
end)
container:SetScript("OnClick", function()
    if IsControlKeyDown() then
        local bgType = TBGH_GetBGType()
        if bgType == "ab" then
            TBGH:AnnounceAB()
        elseif bgType == "wsg" then
            TBGH:AnnounceWSG()
        end
    end
end)

