---------------------------------------------------------------------
-- Auto-size container to fit visible content
---------------------------------------------------------------------
local function ResizeContainer()
    local w = 20
    local h = 0
    if overlay:IsShown() then
        -- Two score rows (Alliance + Horde)
        local hasAlliText = abAlliText:GetText() and abAlliText:GetText() ~= ""
        if hasAlliText then
            h = (AB_SCORE_ROW_HEIGHT * 2) + 6
            local textW = math.max(abAlliText:GetStringWidth() or 0, abHordeText:GetStringWidth() or 0) + 8
            if textW > w then w = textW end
        end
        if overlayText2:GetText() and overlayText2:GetText() ~= "" then
            h = h + 14
            local etaW = (overlayText2:GetStringWidth() or 0) + 8
            if etaW > w then w = etaW end
        end
        if overlayText3:GetText() and overlayText3:GetText() ~= "" then
            h = h + 13
            local winW = (overlayText3:GetStringWidth() or 0) + 8
            if winW > w then w = winW end
        end
    end
    if wsgFrame:IsShown() then
        local classW = WSG_ICON_SIZE + 2  -- class icon + gap
        local alliHPW = (wsgAlliHP:GetStringWidth() or 0)
        local alliDistW = (wsgAlliDist:GetStringWidth() or 0)
        local alliW = WSG_ICON_SIZE + classW + 4 + (wsgAlliText:GetStringWidth() or 0)
        if alliHPW > 0 then alliW = alliW + 4 + alliHPW end
        if alliDistW > 0 then alliW = alliW + 4 + alliDistW end
        local hordeHPW = (wsgHordeHP:GetStringWidth() or 0)
        local hordeDistW = (wsgHordeDist:GetStringWidth() or 0)
        local hordeW = WSG_ICON_SIZE + classW + 4 + (wsgHordeText:GetStringWidth() or 0)
        if hordeHPW > 0 then hordeW = hordeW + 4 + hordeHPW end
        if hordeDistW > 0 then hordeW = hordeW + 4 + hordeDistW end
        local wsgW = math.max(alliW, hordeW)
        local focusW = (wsgFocusedText:GetStringWidth() or 0)
        if focusW > 0 then
            wsgW = wsgW + focusW + 12  -- gap between name/HP and assault text
        end
        if wsgW + 10 > w then w = wsgW + 10 end
        h = WSG_ROW_HEIGHT * 2 + 4
    end
    if h < 12 then h = 12 end
    container:SetWidth(w)
    container:SetHeight(h)
end

local function ResizeBaseContainer()
    if not abBaseFrame:IsShown() then
        baseContainer:Hide()
        return
    end
    local totalBasesW = 5 * (AB_COL_WIDTH + AB_ITEM_SPACING) - AB_ITEM_SPACING
    local w = 8 + totalBasesW + 10 + 14 + 4  -- padding + bases + sep gap + rez icon + margin
    baseContainer:SetWidth(w)
    baseContainer:SetHeight(44)
    baseContainer:Show()
end

---------------------------------------------------------------------
-- AB: Scan raid member positions to count players near each base
---------------------------------------------------------------------
function TBGH:ScanRaidPositions()
    if not self.AB_BASES[1] then return nil end
    local counts = {}
    for i, base in ipairs(self.AB_BASES) do
        counts[i] = 0
    end
    local numMembers = GetNumRaidMembers()
    if numMembers == 0 then return nil end
    SetMapToCurrentZone()
    for r = 1, numMembers do
        local unit = "raid" .. r
        if UnitExists(unit) and not UnitIsDeadOrGhost(unit) then
            local x, y = GetPlayerMapPosition(unit)
            if x and y and (x + y) > 0 then
                for i, base in ipairs(self.AB_BASES) do
                    local dx = x - base.x
                    local dy = y - base.y
                    if (dx * dx + dy * dy) <= (self.AB_BASE_RANGE * self.AB_BASE_RANGE) then
                        counts[i] = counts[i] + 1
                    end
                end
            end
        end
    end
    return counts
end

---------------------------------------------------------------------
-- AB: Detect base ownership via map landmarks
-- Uses texIdx: (texIdx-1)%5 → 0=neutral, 1=alli assaulting, 2=alli controlled, 3=horde assaulting, 4=horde controlled
---------------------------------------------------------------------
-- Map landmark names to our base indices
local LANDMARK_TO_BASE = {
    ["Stables"]    = 1,
    ["Blacksmith"] = 2,
    ["Lumber Mill"]= 3,
    ["Gold Mine"]  = 4,
    ["Farm"]       = 5,
}

function TBGH:GetBaseOwnership()
    local owners = {}  -- per base: TEX_* constant (0-4)
    local rawTexIds = {}  -- per base: raw texIdx for icon display
    SetMapToCurrentZone()
    local numLandmarks = GetNumMapLandmarks()
    for i = 1, numLandmarks do
        local name, desc, texIdx, x, y = GetMapLandmarkInfo(i)
        if name and LANDMARK_TO_BASE[name] then
            local idx = LANDMARK_TO_BASE[name]
            if not self.AB_BASES[idx] then
                self.AB_BASES[idx] = { name = self.AB_BASE_NAMES[name], x = x, y = y }
            end
            local ti = tonumber(texIdx)
            rawTexIds[idx] = ti
            if ti then
                owners[idx] = math.mod(ti - 1, 5)
            else
                owners[idx] = TEX_NEUTRAL
            end
        end
    end
    return owners, rawTexIds
end

function TBGH:UpdateBaseCounts(counts)
    if not self.AB_BASES[1] then
        abBaseFrame:Hide()
        return false
    end
    local faction = UnitFactionGroup("player")
    local isAlliance = (faction == "Alliance")
    local owners, rawTexIds = self:GetBaseOwnership()
    -- Detect state transitions for cap timers
    for i, base in ipairs(self.AB_BASES) do
        local state = owners[i] or TEX_NEUTRAL
        local prev = self.prevOwners[i]
        if prev and prev ~= state then
            if state == TEX_ALLI_ASSAULT or state == TEX_HORDE_ASSAULT then
                -- Assault started
                self.capTimers[i] = GetTime()
            else
                -- No longer assaulting (captured or returned)
                self.capTimers[i] = nil
            end
        end
        self.prevOwners[i] = state
    end
    for i, base in ipairs(self.AB_BASES) do
        local c = counts and counts[i] or 0
        local state = owners[i] or TEX_NEUTRAL
        -- Base name color based on texIdx state
        local nameColor
        if state == TEX_ALLI_CONTROLLED then
            nameColor = "|cff3399ff"  -- blue: Alliance controlled
        elseif state == TEX_HORDE_CONTROLLED then
            nameColor = "|cffff3333"  -- red: Horde controlled
        elseif state == TEX_ALLI_ASSAULT then
            nameColor = "|cff88bbff"  -- light blue: Alliance assaulting
        elseif state == TEX_HORDE_ASSAULT then
            nameColor = "|cffff8888"  -- light red: Horde assaulting
        else
            nameColor = "|cff888888"  -- grey: neutral
        end
        -- Count color based on defense status
        local myControlled = isAlliance and TEX_ALLI_CONTROLLED or TEX_HORDE_CONTROLLED
        local countColor
        if state == myControlled then
            if c >= 2 then
                countColor = "|cff00ff00"  -- green: well defended
            elseif c == 1 then
                countColor = "|cffffff00"  -- yellow: light defense
            else
                countColor = "|cffff8800"  -- orange: undefended
            end
        else
            if c > 0 then
                countColor = "|cffffff00"  -- yellow: attackers
            else
                countColor = "|cff888888"  -- grey
            end
        end
        abBaseNames[i]:SetText(nameColor .. base.name .. "|r")
        abBaseCounts[i]:SetText(countColor .. c .. "|r")
        SetPOIIcon(abBaseIcons[i], rawTexIds[i])
        -- Show sword when attacking, warning when base under-defended
        local si = abBaseColFrames[i].stateIcon
        if state ~= myControlled and c > 0 then
            si:SetTexture("Interface\\Icons\\Ability_Warrior_Charge")
            si:Show()
        elseif state == myControlled and c < 2 then
            si:SetTexture("Interface\\Icons\\Ability_Warrior_ShieldBreak")
            si:Show()
        else
            si:Hide()
        end
    end
    abBaseFrame:Show()
    return true
end

---------------------------------------------------------------------
-- Parse WorldState UI for AB resource counts and base counts
---------------------------------------------------------------------
function TBGH:GetInfo()
    local res, bases = {}, {}
    local n = GetNumWorldStateUI()
    for i = 1, n do
        local uiType, state, text, icon, dynamicIcon, tooltip =
            GetWorldStateUIInfo(i)
        -- In Turtle WoW the score string can be in state or text
        -- Try all non-nil string fields for our patterns
        local fields = {}
        if state and tostring(state) ~= "" then table.insert(fields, tostring(state)) end
        if text and tostring(text) ~= "" then table.insert(fields, tostring(text)) end
        for _, str in ipairs(fields) do
            local _, _, r = string.find(str, "(%d+)/2000")
            if r then
                table.insert(res, tonumber(r))
            end
            local _, _, b = string.find(str, "Bases:%s*(%d+)")
            if b then
                table.insert(bases, tonumber(b))
            end
        end
    end
    return res[1], res[2], bases[1] or nil, bases[2] or nil
end

---------------------------------------------------------------------
-- Guess base count from observed resource rate
---------------------------------------------------------------------
function TBGH:BasesFromRate(rate)
    if not rate or rate <= 0 then return 0 end
    local best, bestDiff = 0, 999
    for b, r in pairs(self.RPS) do
        local d = math.abs(r - rate)
        if d < bestDiff then bestDiff = d; best = b end
    end
    return best
end

---------------------------------------------------------------------
-- Resolve rates (parsed bases -> lookup, or fallback to tracked)
---------------------------------------------------------------------
function TBGH:GetRates(aBases, hBases)
    local aRate, hRate
    if aBases then
        aRate = self.RPS[aBases] or 0
    elseif self.prev.aRate then
        aRate = self.prev.aRate
        aBases = self:BasesFromRate(aRate)
    else
        aRate = 0; aBases = 0
    end
    if hBases then
        hRate = self.RPS[hBases] or 0
    elseif self.prev.hRate then
        hRate = self.prev.hRate
        hBases = self:BasesFromRate(hRate)
    else
        hRate = 0; hBases = 0
    end
    return aRate, hRate, aBases, hBases
end

---------------------------------------------------------------------
-- Core projection logic — returns a summary string
---------------------------------------------------------------------
function TBGH:Project()
    local aRes, hRes, aBases, hBases = self:GetInfo()
    if not aRes or not hRes then return nil end

    local aRate, hRate
    aRate, hRate, aBases, hBases = self:GetRates(aBases, hBases)

    if aRes >= self.MAX then return "|cff60b0ffVICTORY!|r", "|cffffd100" .. hRes .. "|r", nil end
    if hRes >= self.MAX then return "|cffffd100" .. aRes .. "|r", "|cffff6060VICTORY!|r", nil end
    if aRate <= 0 and hRate <= 0 then return nil end

    local aTime = aRate > 0 and (self.MAX - aRes) / aRate or 999999
    local hTime = hRate > 0 and (self.MAX - hRes) / hRate or 999999

    local aFinal, hFinal, eta
    if aTime < hTime then
        aFinal = self.MAX
        hFinal = math.min(self.MAX, math.floor((hRes + hRate * aTime) / 10) * 10)
        eta = aTime
    elseif hTime < aTime then
        aFinal = math.min(self.MAX, math.floor((aRes + aRate * hTime) / 10) * 10)
        hFinal = self.MAX
        eta = hTime
    else
        -- Equal finish times: faction with more resources gets the last tick first
        eta = aTime
        if aRes >= hRes then
            aFinal = self.MAX
            hFinal = math.min(self.MAX, math.floor((hRes + hRate * eta) / 10) * 10)
        else
            hFinal = self.MAX
            aFinal = math.min(self.MAX, math.floor((aRes + aRate * eta) / 10) * 10)
        end
    end

    local mins = math.floor(eta / 60)
    local secs = math.floor(eta - mins * 60)
    local alliColor, hordeColor
    if aFinal >= hFinal then
        alliColor = "|cff60b0ff"  -- light blue = Alliance winning
        hordeColor = "|cff888888"  -- grey = losing
    else
        alliColor = "|cff888888"  -- grey = losing
        hordeColor = "|cffff6060"  -- light red = Horde winning
    end
    local alliLine = string.format("%s%d|r", alliColor, aFinal)
    local hordeLine = string.format("%s%d|r", hordeColor, hFinal)
    local playerWins
    local faction = UnitFactionGroup("player")
    if faction == "Alliance" then
        playerWins = (aFinal >= hFinal)
    else
        playerWins = (hFinal >= aFinal)
    end
    local etaLabel = playerWins and "Win" or "Lose"
    local etaLine = string.format("|cffffd100%s %d:%02d|r", etaLabel, mins, secs)

    -- Calculate min bases needed for each faction to win
    local basesNeeded = self:BasesNeededToWin(aRes, hRes)

    return alliLine, hordeLine, etaLine, basesNeeded
end

---------------------------------------------------------------------
-- Calculate minimum bases needed for player's faction to win
---------------------------------------------------------------------
function TBGH:BasesNeededToWin(aRes, hRes)
    local faction = UnitFactionGroup("player")
    if not faction then return nil end

    local myRes, theirRes
    if faction == "Alliance" then
        myRes = aRes
        theirRes = hRes
    else
        myRes = hRes
        theirRes = aRes
    end

    -- Try each base count from 1 to 5
    for b = 1, 5 do
        local myRate = self.RPS[b] or 0
        local theirRate = self.RPS[5 - b] or 0
        local myTime = myRate > 0 and (self.MAX - myRes) / myRate or 999999
        local theirTime = theirRate > 0 and (self.MAX - theirRes) / theirRate or 999999
        if myTime < theirTime then
            local word = b == 1 and "Base" or "Bases"
            return string.format("|cffffd100Need %d %s|r", b, word)
        end
    end
    return "|cffff0000Can't win|r"
end

---------------------------------------------------------------------
-- Track resource changes to compute observed rates
---------------------------------------------------------------------
function TBGH:TrackRates()
    local aRes, hRes = self:GetInfo()
    if not aRes or not hRes then return end
    local now = GetTime()
    if self.prev.time and (now - self.prev.time) > 2 then
        local dt = now - self.prev.time
        self.prev.aRate = math.max(0, (aRes - self.prev.aRes) / dt)
        self.prev.hRate = math.max(0, (hRes - self.prev.hRes) / dt)
    end
    self.prev.aRes  = aRes
    self.prev.hRes  = hRes
    self.prev.time  = now
end

---------------------------------------------------------------------
-- Update overlay text every world-state tick
---------------------------------------------------------------------
function TBGH:UpdateOverlay()
    local bgType = TBGH_GetBGType()
    if bgType ~= "ab" or db.abEnabled == false then
        abAlliText:SetText("")
        abHordeText:SetText("")
        overlayText2:SetText("")
        overlayText3:SetText("")
        abBaseFrame:Hide()
        baseContainer:Hide()
        overlay:Hide()
        if not wsgFrame:IsShown() then container:Hide() end
        return
    end
    local alliLine, hordeLine, etaLine, basesLine = self:Project()
    local hasBaseDisplay = false
    if db.abBaseDisplayEnabled ~= false then
        hasBaseDisplay = self:UpdateBaseCounts(self.abBaseCounts)
        ResizeBaseContainer()
    else
        abBaseFrame:Hide()
        baseContainer:Hide()
    end
    if not alliLine and hasBaseDisplay then
        -- No score data yet but bases are known — show initial score line
        alliLine = "|cffffd1000|r"
        hordeLine = "|cffffd1000|r"
        etaLine = nil
        basesLine = nil
    end
    if alliLine then
        abAlliText:SetText(alliLine)
        abHordeText:SetText(hordeLine or "")
        overlayText2:SetText(etaLine or "")
        overlayText3:SetText(basesLine or "")
        if containerActiveBG ~= "ab" then
            containerActiveBG = "ab"
            ApplyContainerPos(db.abPos)
        end
        overlay:Show()
        container:Show()
        ResizeContainer()
    elseif hasBaseDisplay then
        abAlliText:SetText("")
        abHordeText:SetText("")
        overlayText2:SetText("")
        overlayText3:SetText("")
        overlay:Hide()
        if not wsgFrame:IsShown() then container:Hide() end
        ResizeContainer()
    else
        abAlliText:SetText("")
        abHordeText:SetText("")
        overlayText2:SetText("")
        overlayText3:SetText("")
        abBaseFrame:Hide()
        baseContainer:Hide()
        overlay:Hide()
        if not wsgFrame:IsShown() then container:Hide() end
        ResizeContainer()
    end
end

---------------------------------------------------------------------
-- AB: Announce to BG chat on Ctrl+click
---------------------------------------------------------------------
function TBGH:AnnounceAB()
    local alliLine, hordeLine, etaLine, basesLine = self:Project()
    if not alliLine then
        DEFAULT_CHAT_FRAME:AddMessage("|cffff4444[TurtlePvP]|r Nothing to announce.")
        return
    end
    local msg = "Alliance: " .. alliLine .. " - Horde: " .. hordeLine
    if etaLine then msg = msg .. "  " .. etaLine end
    if basesLine then msg = msg .. "  " .. basesLine end
    SendChatMessage(msg, "BATTLEGROUND")
end

---------------------------------------------------------------------
-- WSG: Announce flag carriers to BG chat on Ctrl+click
---------------------------------------------------------------------
function TBGH:AnnounceWSG()
    local ac = self.wsg.alliCarrier
    local hc = self.wsg.hordeCarrier
    if not ac and not hc then
        DEFAULT_CHAT_FRAME:AddMessage("|cffff4444[TurtlePvP]|r No flag carriers to announce.")
        return
    end
    local parts = {}
    if hc then
        table.insert(parts, "Alliance Flagcarrier: " .. hc)
    end
    if ac then
        table.insert(parts, "Horde Flagcarrier: " .. ac)
    end
    SendChatMessage(table.concat(parts, " - "), "BATTLEGROUND")
end

---------------------------------------------------------------------
-- WSG: parse BG system messages for flag carrier names
---------------------------------------------------------------------
-- Patterns for flag events (English; adjust if Turtle WoW uses different text)
-- Patterns match against the message text; "side" means which flag is affected
local WSG_PATTERNS = {
    -- Pickup: "The X flag was picked up by Name!"
    { pattern = "The Alliance [Ff]lag was picked up by (.+)!",     side = "alliance", action = "pickup" },
    { pattern = "The Horde [Ff]lag was picked up by (.+)!",        side = "horde",    action = "pickup" },
    { pattern = "(.+) has picked up the Alliance [Ff]lag!",        side = "alliance", action = "pickup" },
    { pattern = "(.+) has picked up the Horde [Ff]lag!",           side = "horde",    action = "pickup" },
    { pattern = "(.+) picked up the Alliance [Ff]lag!",            side = "alliance", action = "pickup" },
    { pattern = "(.+) picked up the Horde [Ff]lag!",               side = "horde",    action = "pickup" },
    -- Dropped
    { pattern = "The Alliance [Ff]lag was dropped",                 side = "alliance", action = "drop" },
    { pattern = "The Horde [Ff]lag was dropped",                    side = "horde",    action = "drop" },
    -- Returned: "The X flag was returned to its base by Name!"
    { pattern = "The Alliance [Ff]lag was returned to its base by (.+)!", side = "alliance", action = "return" },
    { pattern = "The Horde [Ff]lag was returned to its base by (.+)!",   side = "horde",    action = "return" },
    { pattern = "The Alliance [Ff]lag was returned",                side = "alliance", action = "return" },
    { pattern = "The Horde [Ff]lag was returned",                   side = "horde",    action = "return" },
    -- Captured
    { pattern = "The Alliance [Ff]lag was captured by (.+)!",       side = "alliance", action = "capture" },
    { pattern = "The Horde [Ff]lag was captured by (.+)!",          side = "horde",    action = "capture" },
    { pattern = "(.+) captured the Alliance [Ff]lag!",              side = "alliance", action = "capture" },
    { pattern = "(.+) captured the Horde [Ff]lag!",                 side = "horde",    action = "capture" },
    { pattern = "(.+) has captured the Alliance [Ff]lag!",          side = "alliance", action = "capture" },
    { pattern = "(.+) has captured the Horde [Ff]lag!",             side = "horde",    action = "capture" },
}

-- Fallback: if pattern has no capture group but message mentions a flag,
-- try to determine side from the event channel
local function sideFromEvent(ev)
    if ev == "CHAT_MSG_BG_SYSTEM_ALLIANCE" then return "alliance" end
    if ev == "CHAT_MSG_BG_SYSTEM_HORDE" then return "horde" end
    return nil
end

function TBGH:ParseWSGMessage(text, ev)
    if not text then return end
    for _, p in ipairs(WSG_PATTERNS) do
        local _, _, name = string.find(text, p.pattern)
        if string.find(text, p.pattern) then
            if p.action == "pickup" then
                if p.side == "alliance" then
                    self.wsg.alliCarrier = name or "Unknown"
                    self.wsg.alliCarrierLastThreshold = nil  -- Reset threshold for new carrier
                else
                    self.wsg.hordeCarrier = name or "Unknown"
                    self.wsg.hordeCarrierLastThreshold = nil
                end
            elseif p.action == "drop" or p.action == "return" or p.action == "capture" then
                if p.side == "alliance" then
                    self.wsg.alliCarrier = nil
                    self.wsg.alliCarrierLastThreshold = nil
                else
                    self.wsg.hordeCarrier = nil
                    self.wsg.hordeCarrierLastThreshold = nil
                end
            end
            self:UpdateWSGOverlay()
            return
        end
    end
    -- Fallback: no pattern matched but we got a BG system message
    -- Try generic pickup/drop/capture detection using event channel
    local side = sideFromEvent(ev)
    if not side then return end
    local _, _, name = string.find(text, "picked up by (.+)!")
    if not name then _, _, name = string.find(text, "(.+) picked up") end
    if name then
        if side == "alliance" then
            self.wsg.alliCarrier = name
            self.wsg.alliCarrierLastThreshold = nil
        else
            self.wsg.hordeCarrier = name
            self.wsg.hordeCarrierLastThreshold = nil
        end
        self:UpdateWSGOverlay()
        return
    end
    if string.find(text, "dropped") or string.find(text, "returned") or string.find(text, "captured") then
        if side == "alliance" then
            self.wsg.alliCarrier = nil
            self.wsg.alliCarrierLastThreshold = nil
        else
            self.wsg.hordeCarrier = nil
            self.wsg.hordeCarrierLastThreshold = nil
        end
        self:UpdateWSGOverlay()
    end
end

function TBGH:UpdateWSGOverlay()
    local bgType = TBGH_GetBGType()
    if bgType ~= "wsg" or db.wsgEnabled == false then
        wsgFrame:Hide()
        if not overlay:IsShown() then container:Hide() end
        return
    end
    local ac = self.wsg.alliCarrier  -- Horde player carrying Alliance flag
    local hc = self.wsg.hordeCarrier -- Alliance player carrying Horde flag
    -- Alliance side status (hc = Alliance player carrying Horde flag)
    if hc then
        local cc = self:GetClassColorByName(hc) or "ff3399ff"
        wsgAlliText:SetText("|c" .. cc .. hc .. "|r")
        local engClass = self:GetClassByName(hc)
        if engClass and CLASS_TCOORDS[engClass] then
            local tc = CLASS_TCOORDS[engClass]
            wsgAlliClassIcon:SetTexture(CLASS_ICONS)
            wsgAlliClassIcon:SetTexCoord(tc[1], tc[2], tc[3], tc[4])
        else
            wsgAlliClassIcon:SetTexture("Interface\\Icons\\INV_Misc_QuestionMark")
            wsgAlliClassIcon:SetTexCoord(0, 1, 0, 1)
        end
        wsgAlliClassIcon:SetAlpha(1)
        wsgAlliClassIcon:Show()
        local pct = TBGH:GetHealthPct(hc)
        if pct then
            local r, g = 1, 1
            if pct > 50 then r = (100 - pct) / 50 else g = pct / 50 end
            wsgAlliHP:SetTextColor(r, g, 0, 1)
            wsgAlliHP:SetText(pct .. "%")
        else
            wsgAlliHP:SetText("")
        end
        local dist = TBGH:GetDistance(hc)
        if dist then
            if dist <= 20 then
                wsgAlliDist:SetTextColor(1, 0, 0, 1)
            elseif dist <= 40 then
                wsgAlliDist:SetTextColor(1, 1, 0, 1)
            else
                wsgAlliDist:SetTextColor(1, 1, 1, 1)
            end
            wsgAlliDist:SetText(dist .. "yd")
        else
            wsgAlliDist:SetText("")
        end
    else
        wsgAlliText:SetText("")
        wsgAlliHP:SetText("")
        wsgAlliDist:SetText("")
        wsgAlliClassIcon:SetTexture("Interface\\Icons\\INV_Misc_QuestionMark")
        wsgAlliClassIcon:SetTexCoord(0, 1, 0, 1)
        wsgAlliClassIcon:SetAlpha(0.3)
        wsgAlliClassIcon:Show()
    end
    -- Horde side status (ac = Horde player carrying Alliance flag)
    if ac then
        local cc = self:GetClassColorByName(ac) or "ffff3333"
        wsgHordeText:SetText("|c" .. cc .. ac .. "|r")
        local engClass = self:GetClassByName(ac)
        if engClass and CLASS_TCOORDS[engClass] then
            local tc = CLASS_TCOORDS[engClass]
            wsgHordeClassIcon:SetTexture(CLASS_ICONS)
            wsgHordeClassIcon:SetTexCoord(tc[1], tc[2], tc[3], tc[4])
        else
            wsgHordeClassIcon:SetTexture("Interface\\Icons\\INV_Misc_QuestionMark")
            wsgHordeClassIcon:SetTexCoord(0, 1, 0, 1)
        end
        wsgHordeClassIcon:SetAlpha(1)
        wsgHordeClassIcon:Show()
        local pct = TBGH:GetHealthPct(ac)
        if pct then
            local r, g = 1, 1
            if pct > 50 then r = (100 - pct) / 50 else g = pct / 50 end
            wsgHordeHP:SetTextColor(r, g, 0, 1)
            wsgHordeHP:SetText(pct .. "%")
        else
            wsgHordeHP:SetText("")
        end
        local dist = TBGH:GetDistance(ac)
        if dist then
            if dist <= 20 then
                wsgHordeDist:SetTextColor(1, 0, 0, 1)
            elseif dist <= 40 then
                wsgHordeDist:SetTextColor(1, 1, 0, 1)
            else
                wsgHordeDist:SetTextColor(1, 1, 1, 1)
            end
            wsgHordeDist:SetText(dist .. "yd")
        else
            wsgHordeDist:SetText("")
        end
    else
        wsgHordeText:SetText("")
        wsgHordeHP:SetText("")
        wsgHordeDist:SetText("")
        wsgHordeClassIcon:SetTexture("Interface\\Icons\\INV_Misc_QuestionMark")
        wsgHordeClassIcon:SetTexCoord(0, 1, 0, 1)
        wsgHordeClassIcon:SetAlpha(0.3)
        wsgHordeClassIcon:Show()
    end
    if containerActiveBG ~= "wsg" then
        containerActiveBG = "wsg"
        ApplyContainerPos(db.wsgPos or DEFAULT_WSG_POS)
    end
    -- Update Focused Assault display
    local stacks = self:GetFocusedAssaultStacks()
    if stacks > 0 then
        wsgFocusedText:SetText("|cffff6666" .. (stacks * 10) .. "% Assault|r")
    else
        wsgFocusedText:SetText("")
    end
    wsgFrame:Show()
    container:Show()
    ResizeContainer()
    
    -- Auto-announce low health EFC
    self:CheckEFCHealthThresholds()
end

-- Check and announce when enemy flag carrier drops below health thresholds
function TBGH:CheckEFCHealthThresholds()
    -- Check if auto-announce is enabled
    if db.wsgAutoAnnounce == false then return end
    
    local faction = UnitFactionGroup("player")
    if not faction then return end
    
    -- Determine which carrier is the EFC (enemy flag carrier)
    local efcName, efcSide
    if faction == "Alliance" then
        -- EFC is the Horde player carrying Alliance flag
        efcName = self.wsg.alliCarrier
        efcSide = "alli"
    else
        -- EFC is the Alliance player carrying Horde flag
        efcName = self.wsg.hordeCarrier
        efcSide = "horde"
    end
    
    if not efcName then
        -- No EFC, reset threshold
        if efcSide == "alli" then
            self.wsg.alliCarrierLastThreshold = nil
        else
            self.wsg.hordeCarrierLastThreshold = nil
        end
        return
    end
    
    local pct = self:GetHealthPct(efcName)
    if not pct then return end
    
    local lastThreshold = efcSide == "alli" and self.wsg.alliCarrierLastThreshold or self.wsg.hordeCarrierLastThreshold
    local newThreshold = nil
    
    -- Check thresholds (only announce once per threshold)
    if pct <= 20 and lastThreshold ~= 20 then
        newThreshold = 20
    elseif pct <= 40 and pct > 20 and lastThreshold ~= 40 and lastThreshold ~= 20 then
        newThreshold = 40
    end
    
    if newThreshold then
        -- Update threshold tracking
        if efcSide == "alli" then
            self.wsg.alliCarrierLastThreshold = newThreshold
        else
            self.wsg.hordeCarrierLastThreshold = newThreshold
        end
        
        -- Announce to BG chat
        local cc = self:GetClassColorByName(efcName)
        local cOpen = cc and ("|c" .. cc) or "|cffffd100"
        local msg = "EFC LOW: " .. StripColors(cOpen .. efcName .. "|r") .. " - " .. pct .. "% HP!"
        SendChatMessage(msg, "BATTLEGROUND")
    end
end

function TBGH:ResetWSG()
    self.wsg.alliCarrier = nil
    self.wsg.hordeCarrier = nil
    self.wsg.alliCarrierLastThreshold = nil
    self.wsg.hordeCarrierLastThreshold = nil
    self.classCache = {}
    self.guidTracker.nameToGuid = {}
    self.guidTracker.guidToName = {}
    wsgFocusedText:SetText("")
    self:UpdateWSGOverlay()
end

---------------------------------------------------------------------
-- WSG: Detect flag status on mid-game join
-- Uses the dynamic icon on the BG score frames to detect if a flag
-- is already picked up when joining in progress.
-- Also scans raid member buffs for flag carrier detection.
---------------------------------------------------------------------

-- Flag carrier buff textures (vanilla 1.12) — used as candidates, then tooltip-verified
local FLAG_BUFF_CANDIDATES = {
    ["Interface\\Icons\\INV_BannerPVP_02"] = true, -- Alliance banner icon (also used by Battle Standards!)
    ["Interface\\Icons\\INV_BannerPVP_01"] = true, -- Horde banner icon (also used by Battle Standards!)
}

-- Verify a banner buff via tooltip spell name to distinguish real flags from Battle Standards
local function VerifyFlagBuff(unit, buffIndex)
    flagScanTooltip:SetOwner(UIParent, "ANCHOR_NONE")
    flagScanTooltip:ClearLines()
    flagScanTooltip:SetUnitBuff(unit, buffIndex)
    local buffName = TurtlePvPFlagScanTooltipTextLeft1 and TurtlePvPFlagScanTooltipTextLeft1:GetText()
    if not buffName then return nil end
    buffName = string.lower(buffName)
    if string.find(buffName, "silverwing flag") then return "alliance" end
    if string.find(buffName, "warsong flag") then return "horde" end
    return nil  -- Battle Standard or other banner item — ignore
end

local function ScanUnitForFlags(unit, foundAlliCarrier, foundHordeCarrier)
    if not UnitExists(unit) then return foundAlliCarrier, foundHordeCarrier end
    local name = UnitName(unit)
    -- Also harvest GUID while scanning
    TBGH:HarvestGUID(unit)
    local isHostile = UnitIsEnemy("player", unit)
    for b = 1, 32 do
        local tex = UnitBuff(unit, b)
        if not tex then break end
        if FLAG_BUFF_CANDIDATES[tex] then
            -- For friendly units, verify via tooltip to distinguish from Battle Standards
            -- For hostile units, tooltip scanning doesn't work — infer side from texture
            local side
            if isHostile then
                if tex == "Interface\\Icons\\INV_BannerPVP_02" then
                    side = "alliance"
                elseif tex == "Interface\\Icons\\INV_BannerPVP_01" then
                    side = "horde"
                end
            else
                side = VerifyFlagBuff(unit, b)
            end
            if side == "alliance" then
                foundAlliCarrier = name
            elseif side == "horde" then
                foundHordeCarrier = name
            end
        end
    end
    return foundAlliCarrier, foundHordeCarrier
end

function TBGH:ScanRaidForFlagCarriers()
    if TBGH_GetBGType() ~= "wsg" then return end
    local numMembers = GetNumRaidMembers()
    if numMembers == 0 then return end
    local foundAlliCarrier = nil  -- Horde player carrying Alliance flag
    local foundHordeCarrier = nil -- Alliance player carrying Horde flag
    for r = 1, numMembers do
        foundAlliCarrier, foundHordeCarrier = ScanUnitForFlags("raid" .. r, foundAlliCarrier, foundHordeCarrier)
        -- Also check raidNtarget to find enemy FC via teammates' targets
        foundAlliCarrier, foundHordeCarrier = ScanUnitForFlags("raid" .. r .. "target", foundAlliCarrier, foundHordeCarrier)
    end
    -- Also check the player directly (not always in raid list)
    foundAlliCarrier, foundHordeCarrier = ScanUnitForFlags("player", foundAlliCarrier, foundHordeCarrier)
    local changed = false
    -- Update alliance carrier (Horde player with Alliance flag — only detectable if in our raid)
    if foundAlliCarrier and self.wsg.alliCarrier ~= foundAlliCarrier then
        self.wsg.alliCarrier = foundAlliCarrier
        self.wsg.alliCarrierLastThreshold = nil  -- Reset threshold for new carrier
        changed = true
    end
    -- Update horde carrier (Alliance player with Horde flag)
    if foundHordeCarrier and self.wsg.hordeCarrier ~= foundHordeCarrier then
        self.wsg.hordeCarrier = foundHordeCarrier
        self.wsg.hordeCarrierLastThreshold = nil
        changed = true
    end
    if changed then
        self:UpdateWSGOverlay()
    end
end

function TBGH:DetectMidGameFlags()
    if TBGH_GetBGType() ~= "wsg" then return end
    -- First try buff scanning to get actual names
    self:ScanRaidForFlagCarriers()
    -- Fallback: check dynamic icons for flags we couldn't find via buffs
    local hordeIcon = AlwaysUpFrame1DynamicIconButtonIcon
    local alliIcon = AlwaysUpFrame2DynamicIconButtonIcon
    if hordeIcon and hordeIcon:IsVisible() and not self.wsg.hordeCarrier then
        self.wsg.hordeCarrier = "Unknown"
        self.wsg.hordeCarrierLastThreshold = nil
    end
    if alliIcon and alliIcon:IsVisible() and not self.wsg.alliCarrier then
        self.wsg.alliCarrier = "Unknown"
        self.wsg.alliCarrierLastThreshold = nil
    end
    self:UpdateWSGOverlay()
end

---------------------------------------------------------------------
-- Combat module: Tab-skip totems (variables must be before event handler)
---------------------------------------------------------------------
local totemSkipping = false   -- recursion guard
local MAX_TOTEM_SKIPS = 20    -- safety limit per chain

---------------------------------------------------------------------
-- Event handler
---------------------------------------------------------------------
frame:SetScript("OnEvent", function()
    if event == "UPDATE_WORLD_STATES" then
        -- Eagerly populate base data if not yet available
        if TBGH_GetBGType() == "ab" and db.abEnabled ~= false and not TBGH.AB_BASES[1] then
            TBGH:GetBaseOwnership()
            TBGH.abBaseCounts = TBGH:ScanRaidPositions()
        end
        if db.abEnabled ~= false then
            TBGH:TrackRates()
            TBGH:UpdateOverlay()
        end
    elseif event == "CHAT_MSG_BG_SYSTEM_ALLIANCE"
        or event == "CHAT_MSG_BG_SYSTEM_HORDE"
        or event == "CHAT_MSG_BG_SYSTEM_NEUTRAL"
        or event == "CHAT_MSG_RAID_BOSS_EMOTE" then
        if TBGH.wsgDebug then
            DEFAULT_CHAT_FRAME:AddMessage(string.format(
                "|cffffff00[WSG DBG]|r event=%s  msg='%s'",
                tostring(event), tostring(arg1)))
        end
        if db.wsgEnabled ~= false then
            TBGH:ParseWSGMessage(arg1, event)
        end
    elseif event == "PLAYER_TARGET_CHANGED" or event == "UPDATE_MOUSEOVER_UNIT" then
        -- Totem skip: if the new target is a totem, cycle past it
        if event == "PLAYER_TARGET_CHANGED" and db.totemSkip ~= false and not totemSkipping then
            if UnitExists("target") and not UnitIsPlayer("target") then
                local ctype = UnitCreatureType("target")
                local tname = UnitName("target") or ""
                if ctype == "Totem" or string.find(tname, "Totem") then
                    totemSkipping = true
                    for i = 1, MAX_TOTEM_SKIPS do
                        TargetNearestEnemy()
                        -- After each call, check the new target
                        if not UnitExists("target") or UnitIsPlayer("target") then break end
                        local ct2 = UnitCreatureType("target")
                        local tn2 = UnitName("target") or ""
                        if ct2 ~= "Totem" and not string.find(tn2, "Totem") then break end
                    end
                    totemSkipping = false
                    return
                end
            end
        end
        -- Harvest GUID for Nampower tracking
        local unit = (event == "PLAYER_TARGET_CHANGED") and "target" or "mouseover"
        TBGH:HarvestGUID(unit)
        -- Also harvest targettarget
        if event == "PLAYER_TARGET_CHANGED" then
            TBGH:HarvestGUID("targettarget")
        end
        -- WSG: scan target/mouseover (and targettarget) for flag buffs
        -- This catches EFC discovery when targeting them for the first time
        if TBGH_GetBGType() == "wsg" and db.wsgEnabled ~= false then
            local foundA, foundH = ScanUnitForFlags(unit, nil, nil)
            if event == "PLAYER_TARGET_CHANGED" then
                foundA, foundH = ScanUnitForFlags("targettarget", foundA, foundH)
            end
            if foundA and TBGH.wsg.alliCarrier ~= foundA then
                TBGH.wsg.alliCarrier = foundA
                TBGH.wsg.alliCarrierLastThreshold = nil
            end
            if foundH and TBGH.wsg.hordeCarrier ~= foundH then
                TBGH.wsg.hordeCarrier = foundH
                TBGH.wsg.hordeCarrierLastThreshold = nil
            end
            -- Cache class for known carriers
            local uName = UnitName(unit)
            if uName and (uName == TBGH.wsg.alliCarrier or uName == TBGH.wsg.hordeCarrier) then
                local _, engClass = UnitClass(unit)
                if engClass and not TBGH.classCache[uName] then
                    TBGH.classCache[uName] = engClass
                end
            end
            TBGH:UpdateWSGOverlay()
        end
    elseif event == "UNIT_HEALTH_GUID" or event == "UNIT_AURA_GUID" then
        -- Nampower GUID events: arg1 = guid
        TBGH:ProcessGUID(arg1)
    elseif event == "SPELL_START_OTHER" then
        -- Nampower spell event: arg3 = casterGuid
        TBGH:ProcessGUID(arg3)
    elseif event == "VARIABLES_LOADED" then
        ReloadDB()
        -- Detect Nampower and UnitXP availability
        TBGH.hasNampower = (GetNampowerVersion ~= nil)
        TBGH.hasUnitXP = (UnitXP ~= nil)
        -- Register Nampower GUID events if available
        if TBGH.hasNampower then
            frame:RegisterEvent("UNIT_HEALTH_GUID")
            frame:RegisterEvent("UNIT_AURA_GUID")
            frame:RegisterEvent("SPELL_START_OTHER")
        end
        -- Re-apply minimap button position
        UpdateMinimapBtnPos(db.minimapAngle or 225)
        -- Re-apply positions from saved data
        ApplyContainerPos(db.abPos or db.wsgPos or DEFAULT_WSG_POS)
        baseContainer:ClearAllPoints()
        local bp = db.basePos or DEFAULT_BASE_POS
        baseContainer:SetPoint(bp.point, UIParent, bp.relPoint, bp.x, bp.y)
    elseif event == "PLAYER_ENTERING_WORLD" then
        TBGH:ResetWSG()
        TBGH.abBaseCounts = nil
        TBGH.AB_BASES = {}
        TBGH.prev = {}
        TBGH.rezWave = { lastWave = nil, deadSet = {} }
        TBGH.capTimers = {}
        TBGH.prevOwners = {}
        -- Reset active BG and apply saved position immediately
        containerActiveBG = nil
        local bgType = TBGH_GetBGType()
        if bgType == "wsg" then
            containerActiveBG = "wsg"
            ApplyContainerPos(db.wsgPos or DEFAULT_WSG_POS)
        elseif bgType == "ab" then
            containerActiveBG = "ab"
            ApplyContainerPos(db.abPos)
        end
        -- Delayed init (UI needs time to populate)
        TBGH.midGameCheckTimer = 2
        TBGH.abInitTimer = 2
    end
end)

---------------------------------------------------------------------
-- OnUpdate timer: poll raid positions every 2 seconds
---------------------------------------------------------------------
local posTimer = 0
local POS_INTERVAL = 2
local WSG_POS_INTERVAL = 0.1
frame:SetScript("OnUpdate", function()
    local bgType = TBGH_GetBGType()
    -- Mid-game flag detection timer (WSG) — retries a few times for late-loading UI
    if TBGH.midGameCheckTimer then
        TBGH.midGameCheckTimer = TBGH.midGameCheckTimer - arg1
        if TBGH.midGameCheckTimer <= 0 then
            -- Force re-apply WSG position after UI settles (first attempt only)
            if bgType == "wsg" and not TBGH.midGameCheckRetries then
                containerActiveBG = "wsg"
                ApplyContainerPos(db.wsgPos or DEFAULT_WSG_POS)
                posTimer = 0
            end
            TBGH:DetectMidGameFlags()
            -- Retry up to 3 more times (at 4s, 6s, 8s) if any carrier is still "Unknown" or nil
            TBGH.midGameCheckRetries = (TBGH.midGameCheckRetries or 0) + 1
            local needsRetry = bgType == "wsg" and TBGH.midGameCheckRetries <= 3
                and (TBGH.wsg.alliCarrier == "Unknown" or TBGH.wsg.hordeCarrier == "Unknown"
                     or (not TBGH.wsg.alliCarrier and not TBGH.wsg.hordeCarrier))
            if needsRetry then
                TBGH.midGameCheckTimer = 2  -- retry in 2 more seconds
            else
                TBGH.midGameCheckTimer = nil
                TBGH.midGameCheckRetries = nil
            end
        end
    end
    -- AB initial scan after entering BG
    if TBGH.abInitTimer then
        TBGH.abInitTimer = TBGH.abInitTimer - arg1
        if TBGH.abInitTimer <= 0 then
            TBGH.abInitTimer = nil
            if bgType == "ab" then
                -- Force re-apply positions after UI settles
                containerActiveBG = "ab"
                ApplyContainerPos(db.abPos)
                baseContainer:ClearAllPoints()
                local bp = db.basePos or DEFAULT_BASE_POS
                baseContainer:SetPoint(bp.point, UIParent, bp.relPoint, bp.x, bp.y)
                posTimer = 0
                TBGH:GetBaseOwnership()
                TBGH.abBaseCounts = TBGH:ScanRaidPositions()
                TBGH:TrackRates()
                TBGH:UpdateOverlay()
            end
        end
    end
    -- AB position polling
    if bgType == "ab" and db.abEnabled ~= false then
        posTimer = posTimer + arg1
        if posTimer >= POS_INTERVAL then
            posTimer = 0
            TBGH:GetBaseOwnership()
            TBGH.abBaseCounts = TBGH:ScanRaidPositions()
            TBGH:UpdateOverlay()
            -- Rez wave detection: track dead->alive transitions
            TBGH:DetectRezWave()
        end
    end
    -- WSG: periodically scan raid buffs for flag carriers
    if bgType == "wsg" and db.wsgEnabled ~= false then
        posTimer = posTimer + arg1
        if posTimer >= WSG_POS_INTERVAL then
            posTimer = 0
            TBGH:ScanRaidForFlagCarriers()
            TBGH:UpdateWSGOverlay()
        end
    end
    -- Update rez countdown display every frame
    if bgType == "ab" or bgType == "wsg" then
        TBGH:UpdateRezCountdown()
    end
    -- Update cap timer overlays every frame
    if bgType == "ab" then
        TBGH:UpdateCapOverlays()
    end
end)

---------------------------------------------------------------------
-- Rez wave detection: scan raid for dead->alive transitions
---------------------------------------------------------------------
function TBGH:DetectRezWave()
    local numMembers = GetNumRaidMembers()
    if numMembers == 0 then return end
    local oldDead = self.rezWave.deadSet
    local newDead = {}
    local rezzedCount = 0
    for r = 1, numMembers do
        local unit = "raid" .. r
        if UnitExists(unit) then
            local name = UnitName(unit)
            if UnitIsDeadOrGhost(unit) then
                newDead[name] = true
            elseif name and oldDead[name] then
                -- Was dead, now alive
                rezzedCount = rezzedCount + 1
            end
        end
    end
    self.rezWave.deadSet = newDead
    -- If 2+ players rezzed simultaneously, it's a spirit healer wave
    if rezzedCount >= 2 then
        local now = GetTime()
        if self.rezWave.lastWave then
            -- Snap to nearest 30s boundary from last known wave to reduce drift
            local elapsed = now - self.rezWave.lastWave
            local cycles = math.floor((elapsed + 15) / 30)
            if cycles < 1 then cycles = 1 end
            self.rezWave.lastWave = self.rezWave.lastWave + cycles * 30
        else
            -- First detection: compensate for avg scan delay (~1s)
            self.rezWave.lastWave = now - 1
        end
    end
end

function TBGH:UpdateRezCountdown()
    if not self.rezWave.lastWave then
        rezCountdown:SetText("")
        return
    end
    local elapsed = GetTime() - self.rezWave.lastWave
    local remaining = 30 - math.mod(elapsed, 30)
    local secs = math.ceil(remaining)
    if secs > 30 then secs = 30 end
    local color
    -- Smooth transition: yellow (1,1,0) at 30s → green (0,1,0) at 0s
    local t = secs / 30  -- 1 at 30s, 0 at 0s
    local r = t  -- 1→0
    local g = 1
    local b = 0
    rezCountdown:SetTextColor(r, g, b, 1)
    rezCountdown:SetText(secs .. "s")
end

---------------------------------------------------------------------
-- Cap timer: vertical fill overlay on base icons
-- Overlay shrinks from full-height to 0 over 60 seconds,
-- revealing the icon from bottom to top as the cap progresses.
---------------------------------------------------------------------
function TBGH:UpdateCapOverlays()
    for i = 1, 5 do
        local startTime = self.capTimers[i]
        if startTime then
            local elapsed = GetTime() - startTime
            local remaining = math.ceil(self.CAP_DURATION - elapsed)
            if remaining <= 0 then
                abCapTimerTexts[i]:SetText("")
            else
                abCapTimerTexts[i]:SetText(tostring(remaining))
            end
        else
            abCapTimerTexts[i]:SetText("")
        end
    end
end

---------------------------------------------------------------------
-- Chat estimate (verbose version)
---------------------------------------------------------------------
function TBGH:Estimate()
    local aRes, hRes, aBases, hBases = self:GetInfo()
    local msg = DEFAULT_CHAT_FRAME
    if not aRes or not hRes then
        msg:AddMessage("|cffff4444[TurtlePvP]|r Not in AB or can't read scores. Use /tbgdebug")
        return
    end

    local aRate, hRate
    aRate, hRate, aBases, hBases = self:GetRates(aBases, hBases)

    msg:AddMessage("|cffffff00========= TurtlePvP Estimate =========|r")
    msg:AddMessage(string.format(
        "|cff3399ffAlliance:|r  %d/%d  |  Bases: %d  |  %.1f res/s",
        aRes, self.MAX, aBases, aRate))
    msg:AddMessage(string.format(
        "|cffff3333Horde:|r     %d/%d  |  Bases: %d  |  %.1f res/s",
        hRes, self.MAX, hBases, hRate))

    if aRes >= self.MAX then
        msg:AddMessage("|cff3399ff >> Alliance has won!|r"); return
    end
    if hRes >= self.MAX then
        msg:AddMessage("|cffff3333 >> Horde has won!|r"); return
    end
    if aRate <= 0 and hRate <= 0 then
        msg:AddMessage("|cffffff00 Both rates are 0 — can't project.|r"); return
    end

    local aTime = aRate > 0 and (self.MAX - aRes) / aRate or 999999
    local hTime = hRate > 0 and (self.MAX - hRes) / hRate or 999999

    if aTime < hTime then
        local hFinal = math.min(self.MAX, math.floor(hRes + hRate * aTime))
        msg:AddMessage(string.format(
            " >> Projected: |cff3399ffAlliance|r wins  |cffffff00%d|r - |cff888888%d|r",
            self.MAX, hFinal))
        msg:AddMessage(string.format(
            "|cffffff00 >> ETA: ~%d sec (%.1f min)|r",
            math.ceil(aTime), aTime / 60))
    elseif hTime < aTime then
        local aFinal = math.min(self.MAX, math.floor(aRes + aRate * hTime))
        msg:AddMessage(string.format(
            " >> Projected: |cffff3333Horde|r wins  |cff888888%d|r - |cffffff00%d|r",
            aFinal, self.MAX))
        msg:AddMessage(string.format(
            "|cffffff00 >> ETA: ~%d sec (%.1f min)|r",
            math.ceil(hTime), hTime / 60))
    else
        msg:AddMessage("|cffffff00 >> Dead heat — both teams on pace to tie!|r")
    end

    local basesNeeded = self:BasesNeededToWin(aRes, hRes)
    if basesNeeded then
        msg:AddMessage(" >> " .. basesNeeded)
    end

    msg:AddMessage("|cffffff00======================================|r")
end

---------------------------------------------------------------------
-- Debug: dump raw WorldState entries
---------------------------------------------------------------------
function TBGH:Debug()
    local msg = DEFAULT_CHAT_FRAME
    local n = GetNumWorldStateUI()
    msg:AddMessage("|cffffff00== TurtlePvP WorldState Debug (" .. n .. " entries) ==|r")
    for i = 1, n do
        local uiType, state, text, icon = GetWorldStateUIInfo(i)
        msg:AddMessage(string.format(
            "  [%d] state=%s  text='%s'  icon='%s'",
            i, tostring(state), tostring(text), tostring(icon)))
    end
end

